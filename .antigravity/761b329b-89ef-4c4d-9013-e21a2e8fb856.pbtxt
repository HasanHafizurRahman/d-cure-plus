  file_change {
    absolute_path_uri: "file:///src/components/DosageGuide.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import { useState } from \'react\';\nimport { CheckCircle2, AlertTriangle, Check, RefreshCw, Sparkles } from \'lucide-react\';\nimport { motion, AnimatePresence } from \'motion/react\';\n\nexport default function DosageGuide() {\n  // Dosage state for interactive dosage tracker\n  const [morningTaken, setMorningTaken] = useState(false);\n  const [nightTaken, setNightTaken] = useState(false);\n\n  // Calculate completion percentage\n  const totalSlots = 2;\n  const takenCount = (morningTaken ? 1 : 0) + (nightTaken ? 1 : 0);\n  const progressPercent = (takenCount / totalSlots) * 100;\n\n  const handleReset = () => {\n    setMorningTaken(false);\n    setNightTaken(false);\n  };\n\n  return (\n    <section className=\"py-16 bg-gradient-to-b from-white to-[#f7faf8]\">\n      <div className=\"max-w-(--spacing-container-max) mx-auto px-4 sm:px-6 lg:px-8\">\n        \n        {/* Card Frame wrapping content */}\n        <div className=\"bg-white border border-slate-200 rounded-2xl p-6 md:p-12 shadow-sm relative overflow-hidden grid grid-cols-1 lg:grid-cols-12 gap-12 items-center\">\n          \n          {/* Decorative faint background element */}\n          <div className=\"absolute top-0 right-0 w-32 h-32 bg-[#b2f0cc]/10 rounded-full blur-2xl\"></div>\n\n          {/* Left Column: Realistic Product Media & Interactive Dosage Widget */}\n          <div className=\"col-span-1 lg:col-span-6 flex flex-col space-y-6\" id=\"dosage-media-container\">\n            {/* Curated Wellness Photo representing herbal capsule setup */}\n            <div className=\"relative w-full h-56 sm:h-72 overflow-hidden rounded-xl bg-slate-100 border border-slate-200 shadow-xs\">\n              <img \n                src=\"https://images.unsplash.com/photo-1471864190281-a93a3070b6de?auto=format&fit=crop&w=800&q=80\" \n                alt=\"Natural herbal wellness capsule and therapy display\"\n                className=\"w-full h-full object-cover\"\n                referrerPolicy=\"no-referrer\"\n              />\n              <div className=\"absolute top-3 left-3 bg-[#0d4d33] text-white font-display text-xs px-2.5 py-1 rounded shadow-xs font-semibold\">\n                \340\247\247\340\247\250\340\247\246\340\246\237\340\246\277 \340\246\225\340\247\215\340\246\257\340\246\276\340\246\252\340\246\270\340\247\201\340\246\262 \340\246\252\340\247\215\340\246\257\340\246\276\340\246\225\n              </div>\n            </div>\n\n            {/* Interactive Dosage Tracker (Specialized visual component from guidelines) */}\n            <div className=\"bg-[#f7faf8] border border-[#e0e6e2] p-5 rounded-xl text-left bangla-text\" id=\"interactive-dosage-tracker\">\n              <div className=\"flex justify-between items-center mb-4\">\n                <h4 className=\"text-base font-display font-bold text-primary-dark flex items-center gap-2\">\n                  <span className=\"w-2.5 h-2.5 bg-brand-green rounded-full\"></span>\n                  \340\246\206\340\246\234\340\246\225\340\247\207\340\246\260 \340\246\241\340\247\213\340\246\234 \340\246\237\340\247\215\340\246\260\340\247\215\340\246\257\340\246\276\340\246\225\340\246\276\340\246\260 (\340\246\241\340\246\276\340\247\237\340\246\276\340\246\254\340\247\207\340\246\237\340\246\277\340\246\270 \340\246\250\340\246\277\340\247\237\340\246\250\340\247\215\340\246\244\340\247\215\340\246\260\340\246\243)\n                </h4>\n                <button \n                  onClick={handleReset}\n                  className=\"p-1 px-2.5 rounded-md hover:bg-slate-200 text-primary-dark/70 text-xs font-display flex items-center gap-1.5 cursor-pointer bg-white border border-slate-200 transition-colors\"\n                >\n                  <RefreshCw size={12} />\n                  \340\246\260\340\246\277\340\246\270\340\247\207\340\246\237 \340\246\225\340\246\260\340\247\201\340\246\250\n                </button>\n              </div>\n\n              <div className=\"grid grid-cols-1 sm:grid-cols-12 gap-6 items-center\">\n                {/* Progress Circle & Needle */}\n                <div className=\"sm:col-span-4 flex flex-col items-center\">\n                  <div className=\"relative w-28 h-28 flex justify-center items-center\">\n                    {/* Circle Background */}\n                    <svg className=\"w-full h-full transform -rotate-90\">\n                      <circle\n                        cx=\"56\"\n                        cy=\"56\"\n                        r=\"45\"\n                        className=\"stroke-slate-200\"\n                        strokeWidth=\"8\"\n                        fill=\"transparent\"\n                      />\n                      <circle\n                        cx=\"56\"\n                        cy=\"56\"\n                        r=\"45\"\n                        className=\"stroke-brand-green transition-all duration-500 ease-out\"\n                        strokeWidth=\"8\"\n                        fill=\"transparent\"\n                        strokeDasharray={282}\n                        strokeDashoffset={282 - (282 * progressPercent) / 100}\n                        strokeLinecap=\"round\"\n                      />\n                    </svg>\n                    \n                    {/* Inner Indicator showing Percent/Status */}\n                    <div className=\"absolute flex flex-col items-center justify-center font-display\">\n                      <span className=\"text-xl font-bold text-primary-dark text-center\">{progressPercent}%</span>\n                      <span className=\"text-[10px] text-primary-dark/70\">\340\246\225\340\246\276\340\246\260\340\247\215\340\246\257 \340\246\270\340\246\256\340\247\215\340\246\252\340\246\250\340\247\215\340\246\250</span>\n                    </div>\n\n                    {/* Gold needle indicator accent */}\n                    <div \n                      className=\"absolute w-2 h-14 bottom-14 origin-bottom transition-all duration-500 ease-out\"\n                      style={{ transform: `rotate(${(progressPercent * 1.8) - 90}deg)` }}\n                    >\n                      <div className=\"w-1.5 h-1.5 bg-accent-gold rounded-full mx-auto shadow-xs\"></div>\n                    </div>\n                  </div>\n                </div>\n\n                {/* Tracking Action Buttons */}\n                <div className=\"sm:col-span-8 flex flex-col space-y-3 font-display\">\n                  <button\n                    onClick={() => setMorningTaken(!morningTaken)}\n                    className={`w-full flex items-center justify-between p-3 rounded-lg border font-semibold text-sm transition-all duration-200 cursor-pointer ${\n                      morningTaken \n                        ? \'bg-brand-green/10 border-brand-green text-brand-green\' \n                        : \'bg-white border-slate-200 text-primary-dark hover:border-slate-300\'\n                    }`}\n                  >\n                    <span className=\"flex items-center gap-2\">\n                       \342\230\200\357\270\217 \340\246\270\340\246\225\340\246\276\340\246\262\340\247\207\340\246\260 \340\246\241\340\247\213\340\246\234 (\340\246\226\340\246\276\340\246\254\340\246\276\340\246\260\340\247\207\340\246\260 \340\247\251\340\247\246\340\246\256\340\246\277: \340\246\252\340\247\202\340\246\260\340\247\215\340\246\254\340\247\207)\n                    </span>\n                    <span className={`w-5 h-5 rounded-full flex items-center justify-center border transition-colors ${\n                      morningTaken ? \'bg-brand-green border-brand-green text-white\' : \'border-slate-300 bg-white\'\n                    }`}>\n                      {morningTaken && <Check size={12} className=\"stroke-[3]\" />}\n                    </span>\n                  </button>\n\n                  <button\n                    onClick={() => setNightTaken(!nightTaken)}\n                    className={`w-full flex items-center justify-between p-3 rounded-lg border font-semibold text-sm transition-all duration-200 cursor-pointer ${\n                      nightTaken \n                        ? \'bg-brand-green/10 border-brand-green text-brand-green\' \n                        : \'bg-white border-slate-200 text-primary-dark hover:border-slate-300\'\n                    }`}\n                  >\n                    <span className=\"flex items-center gap-2\">\n                      \360\237\214\231 \340\246\260\340\246\276\340\246\244\340\247\207\340\246\260 \340\246\241\340\247\213\340\246\234 (\340\246\226\340\246\276\340\246\254\340\246\276\340\246\260\340\247\207\340\246\260 \340\247\251\340\247\246\340\246\256\340\246\277: \340\246\252\340\247\202\340\246\260\340\247\215\340\246\254\340\247\207)\n                    </span>\n                    <span className={`w-5 h-5 rounded-full flex items-center justify-center border transition-colors ${\n                      nightTaken ? \'bg-brand-green border-brand-green text-white\' : \'border-slate-300 bg-white\'\n                    }`}>\n                      {nightTaken && <Check size={12} className=\"stroke-[3]\" />}\n                    </span>\n                  </button>\n                </div>\n              </div>\n\n              {/* Achievement Message */}\n              <AnimatePresence>\n                {progressPercent === 100 && (\n                  <motion.div\n                    initial={{ opacity: 0, height: 0 }}\n                    animate={{ opacity: 1, height: \'auto\' }}\n                    exit={{ opacity: 0, height: 0 }}\n                    className=\"mt-4 p-3 bg-brand-green border border-brand-green/20 rounded-lg text-white flex items-center gap-2.5 text-xs font-semibold\"\n                  >\n                    <Sparkles size={16} className=\"text-accent-gold shrink-0 animate-bounce\" />\n                    <span>\340\246\205\340\246\270\340\246\276\340\246\247\340\246\276\340\246\260\340\246\243 \340\246\225\340\246\276\340\246\234! \340\246\206\340\246\252\340\246\250\340\246\276\340\246\260 \340\246\206\340\246\234\340\246\225\340\247\207\340\246\260 \340\246\270\340\247\207\340\246\254\340\246\250 \340\246\270\340\246\256\340\247\215\340\246\252\340\247\202\340\246\260\340\247\215\340\246\243 \340\246\271\340\247\237\340\247\207\340\246\233\340\247\207\340\245\244 \340\246\241\340\246\276\340\247\237\340\246\276\340\246\254\340\247\207\340\246\237\340\246\277\340\246\270 \340\246\250\340\246\277\340\247\237\340\246\250\340\247\215\340\246\244\340\247\215\340\246\260\340\246\243\340\247\207 \340\246\250\340\246\277\340\247\237\340\246\256\340\246\277\340\246\244 \340\246\271\340\247\213\340\246\250\340\245\244</span>\n                  </motion.div>\n                )}\n              </AnimatePresence>\n            </div>\n          </div>\n\n          {/* Right Column: Descriptions & Guidelines (Matches Screenshot perfectly) */}\n          <div className=\"col-span-1 lg:col-span-6 flex flex-col text-left space-y-6 bangla-text\" id=\"dosage-text-container\">\n            <div className=\"space-y-2\">\n              <span className=\"text-brand-green text-xs font-bold uppercase tracking-wider font-sans\">\340\246\250\340\246\277\340\246\260\340\247\215\340\246\246\340\247\207\340\246\266\340\246\276\340\246\254\340\246\262\340\247\200</span>\n              <h3 className=\"text-xl sm:text-2xl md:text-3xl font-display font-bold text-primary-dark\">\n                \340\246\250\340\246\277\340\246\260\340\247\215\340\246\246\340\247\207\340\246\266\340\246\250\340\246\276 \340\246\223 \340\246\270\340\247\207\340\246\254\340\246\250\340\246\254\340\246\277\340\246\247\340\246\277\n              </h3>\n            </div>\n            \n            <div className=\"w-12 h-1 bg-brand-green rounded-full\"></div>\n\n            <div className=\"space-y-6 py-2\">\n              {/* Point 1: Dosage */}\n              <div className=\"flex gap-4 items-start group\">\n                <div className=\"w-10 h-10 rounded-full bg-brand-green/10 flex justify-center items-center border border-brand-green/15 text-brand-green shrink-0 mt-0.5 group-hover:scale-105 transition-transform duration-200\">\n                  <CheckCircle2 size={20} />\n                </div>\n                <div className=\"space-y-1\">\n                  <h4 className=\"text-lg font-display font-semibold text-primary-dark\">\340\246\270\340\247\207\340\246\254\340\246\250 \340\246\256\340\246\276\340\246\244\340\247\215\340\246\260\340\246\276:</h4>\n                  <p className=\"text-sm sm:text-base text-primary-dark/85 font-sans\">\n                    \340\247\247\340\246\237\340\246\277 \340\246\225\340\246\260\340\247\207 \340\246\225\340\247\215\340\246\257\340\246\276\340\246\252\340\246\270\340\247\201\340\246\262 \340\246\252\340\247\215\340\246\260\340\246\244\340\246\277\340\246\246\340\246\277\340\246\250 \340\246\270\340\246\225\340\246\276\340\246\262\340\247\207 \340\246\217\340\246\254\340\246\202 \340\246\260\340\246\276\340\246\244\340\247\207 \340\246\226\340\246\276\340\246\254\340\246\276\340\246\260\340\247\207\340\246\260 \340\247\251\340\247\246 \340\246\256\340\246\277\340\246\250\340\246\277\340\246\237 \340\246\206\340\246\227\340\247\207 \340\246\270\340\247\207\340\246\254\340\247\215\340\246\257 \340\246\205\340\246\245\340\246\254\340\246\276 \340\246\232\340\246\277\340\246\225\340\246\277\340\247\216\340\246\270\340\246\225\340\247\207\340\246\260 \340\246\252\340\246\260\340\246\276\340\246\256\340\246\260\340\247\215\340\246\266 \340\246\205\340\246\250\340\247\201\340\246\257\340\246\276\340\247\237\340\247\200 \340\246\270\340\247\207\340\246\254\340\247\215\340\246\257\340\245\244\n                  </p>\n                </div>\n              </div>\n\n              {/* Point 2: Caution */}\n              <div className=\"flex gap-4 items-start group\">\n                <div className=\"w-10 h-10 rounded-full bg-accent-gold/15 flex justify-center items-center border border-accent-gold/30 text-accent-dark-gold shrink-0 mt-0.5 group-hover:scale-105 transition-transform duration-200\">\n                  <AlertTriangle size={20} />\n                </div>\n                <div className=\"space-y-1\">\n                  <h4 className=\"text-lg font-display font-semibold text-primary-dark\">\340\246\270\340\246\244\340\246\260\340\247\215\340\246\225\340\246\244\340\246\276:</h4>\n                  <p className=\"text-sm sm:text-base text-primary-dark/85 font-sans\">\n                    \340\246\206\340\246\262\340\247\213 \340\246\223 \340\246\206\340\246\260\340\247\215\340\246\246\340\247\215\340\246\260\340\246\244\340\246\276 \340\246\245\340\247\207\340\246\225\340\247\207 \340\246\246\340\247\202\340\246\260\340\247\207, \340\246\240\340\246\276\340\246\250\340\247\215\340\246\241\340\246\276 \340\246\223 \340\246\266\340\247\201\340\246\267\340\247\215\340\246\225 \340\246\270\340\247\215\340\246\245\340\246\276\340\246\250\340\247\207 \340\246\260\340\246\276\340\246\226\340\247\201\340\246\250\340\245\244 \340\246\252\340\247\215\340\246\260\340\246\244\340\246\277\340\246\237\340\246\277 \340\246\270\340\247\207\340\246\254\340\246\250\340\247\207\340\246\260 \340\246\252\340\246\260 \340\246\225\340\246\250\340\246\237\340\247\207\340\246\207\340\246\250\340\246\276\340\246\260\340\247\207\340\246\260 \340\246\225\340\247\215\340\246\257\340\246\276\340\246\252 \340\246\255\340\246\276\340\246\262\340\247\213 \340\246\225\340\246\260\340\247\207 \340\246\206\340\246\237\340\246\225\340\246\276\340\246\250\340\245\244 \340\246\266\340\246\277\340\246\266\340\247\201\340\246\246\340\247\207\340\246\260 \340\246\250\340\246\276\340\246\227\340\246\276\340\246\262\340\247\207\340\246\260 \340\246\254\340\246\276\340\246\207\340\246\260\340\247\207 \340\246\260\340\246\276\340\246\226\340\247\201\340\246\250\340\245\244\n                  </p>\n                </div>\n              </div>\n            </div>\n\n            {/* Disclaimer block */}\n            <div className=\"p-4 bg-slate-50 border border-slate-200 rounded-lg text-xs text-primary-dark/70 font-sans\">\n              * \340\246\250\340\247\213\340\246\237: \340\246\207\340\246\211\340\246\250\340\246\276\340\246\250\340\247\200 \340\246\224\340\246\267\340\246\247 \340\246\270\340\246\256\340\247\215\340\246\252\340\247\202\340\246\260\340\247\215\340\246\243 \340\246\252\340\246\276\340\246\260\340\247\215\340\246\266\340\247\215\340\246\254\340\246\252\340\247\215\340\246\260\340\246\244\340\246\277\340\246\225\340\247\215\340\246\260\340\246\277\340\247\237\340\246\276\340\246\256\340\247\201\340\246\225\340\247\215\340\246\244\340\245\244 \340\246\244\340\246\254\340\247\207 \340\246\225\340\247\213\340\246\250\340\247\213 \340\246\246\340\247\200\340\246\260\340\247\215\340\246\230\340\246\270\340\247\215\340\246\245\340\246\276\340\247\237\340\247\200 \340\246\270\340\246\256\340\246\270\340\247\215\340\246\257\340\246\276 \340\246\245\340\246\276\340\246\225\340\246\262\340\247\207 \340\246\254\340\246\276 \340\246\205\340\246\250\340\247\215\340\246\257\340\246\276\340\246\250\340\247\215\340\246\257 \340\246\224\340\246\267\340\246\247 \340\246\270\340\247\207\340\246\254\340\246\250\340\247\207\340\246\260 \340\246\252\340\247\215\340\246\260\340\246\276\340\246\225\340\247\215\340\246\225\340\246\276\340\246\262\340\247\207 \340\246\232\340\246\277\340\246\225\340\246\277\340\247\216\340\246\270\340\246\225\340\247\207\340\246\260 \340\246\252\340\246\260\340\246\276\340\246\256\340\246\260\340\247\215\340\246\266 \340\246\227\340\247\215\340\246\260\340\246\271\340\246\243 \340\246\225\340\246\260\340\246\276 \340\246\254\340\246\276\340\246\236\340\247\215\340\246\233\340\246\250\340\247\200\340\247\237\340\245\244\n            </div>\n          </div>\n\n        </div>\n\n      </div>\n    </section>\n  );\n}\n"
