    replacement_chunks {
      replacement_content: "import { Award, ShieldAlert, HeartPulse, RefreshCcw } from \'lucide-react\';\nimport { motion } from \'motion/react\';\n\nexport default function BannerMiddle() {\n  return (\n    <section className=\"py-16 bg-[#003520] text-white relative overflow-hidden bangla-text\">\n      {/* Absolute vectors */}\n      <div className=\"absolute top-0 left-0 w-80 h-80 bg-[#125136]/50 rounded-full blur-3xl -z-5\"></div>\n      <div className=\"absolute bottom-0 right-0 w-96 h-96 bg-[#fed65b]/5 rounded-full blur-3xl -z-5\"></div>\n\n      <div className=\"max-w-(--spacing-container-max) mx-auto px-4 sm:px-6 lg:px-8 relative z-10\">\n        <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-12 items-center\">\n          \n          {/* Left Column: Visual Grid of Laboratory Certificates */}\n          <div className=\"col-span-1 lg:col-span-5 grid grid-cols-2 gap-4\" id=\"cert-badge-grid\">\n            <motion.div \n              whileHover={{ scale: 1.03 }}\n              className=\"bg-white/10 p-5 rounded-lg border border-white/10 flex flex-col items-center text-center space-y-2 backdrop-blur-xs\"\n            >\n              <Award className=\"text-accent-gold w-8 h-8\" />\n              <h4 className=\"text-base font-display font-semibold\">\340\246\207\340\246\211\340\246\250\340\246\276\340\246\250\340\247\200 \340\246\205\340\246\250\340\247\201\340\246\256\340\247\213\340\246\246\340\246\277\340\246\244</h4>\n              <p className=\"text-[11px] text-white/80 font-sans\">\340\247\247\340\247\246\340\247\246% \340\246\255\340\247\207\340\246\267\340\246\234 \340\246\211\340\246\252\340\246\276\340\246\246\340\246\276\340\246\250</p>\n            </motion.div>\n\n            <motion.div \n              whileHover={{ scale: 1.03 }}\n              className=\"bg-white/10 p-5 rounded-lg border border-white/10 flex flex-col items-center text-center space-y-2 backdrop-blur-xs\"\n            >\n              <HeartPulse className=\"text-accent-gold w-8 h-8\" />\n              <h4 className=\"text-base font-display font-semibold\">\340\246\260\340\246\225\340\247\215\340\246\244\340\247\207\340\246\260 \340\246\270\340\247\201\340\246\227\340\246\276\340\246\260 \340\246\250\340\246\277\340\247\237\340\246\250\340\247\215\340\246\244\340\247\215\340\246\260\340\246\243</h4>\n              <p className=\"text-[11px] text-white/80 font-sans\">\340\246\227\340\247\215\340\246\262\340\247\201\340\246\225\340\247\213\340\246\234 \340\246\262\340\247\207\340\246\255\340\247\207\340\246\262 \340\246\270\340\247\215\340\246\254\340\246\276\340\246\255\340\246\276\340\246\254\340\246\277\340\246\225 \340\246\260\340\246\276\340\246\226\340\247\207</p>\n            </motion.div>\n\n            <motion.div \n              whileHover={{ scale: 1.03 }}\n              className=\"bg-white/10 p-5 rounded-lg border border-white/10 flex flex-col items-center text-center space-y-2 backdrop-blur-xs\"\n            >\n              <ShieldAlert className=\"text-accent-gold w-8 h-8\" />\n              <h4 className=\"text-base font-display font-semibold\">\340\246\225\340\247\213\340\246\250\340\247\213 \340\246\252\340\246\276\340\246\260\340\247\215\340\246\266\340\247\215\340\246\254\340\246\252\340\247\215\340\246\260\340\246\244\340\246\277\340\246\225\340\247\215\340\246\260\340\246\277\340\247\237\340\246\276 \340\246\250\340\247\207\340\246\207</h4>\n              <p className=\"text-[11px] text-white/80 font-sans\">\340\246\260\340\246\276\340\246\270\340\246\276\340\247\237\340\246\250\340\246\277\340\246\225 \340\246\211\340\246\252\340\246\276\340\246\246\340\246\276\340\246\250\340\246\256\340\247\201\340\246\225\340\247\215\340\246\244</p>\n            </motion.div>\n\n            <motion.div \n              whileHover={{ scale: 1.03 }}\n              className=\"bg-white/10 p-5 rounded-lg border border-white/10 flex flex-col items-center text-center space-y-2 backdrop-blur-xs\"\n            >\n              <RefreshCcw className=\"text-accent-gold w-8 h-8\" />\n              <h4 className=\"text-base font-display font-semibold\">\340\247\252\340\247\246\340\247\246 \340\246\237\340\246\276\340\246\225\340\246\276 \340\246\270\340\246\276\340\246\266\340\247\215\340\246\260\340\247\237\340\247\200 \340\246\205\340\246\253\340\246\276\340\246\260</h4>\n              <p className=\"text-[11px] text-white/80 font-sans\">\340\247\250\340\246\237\340\246\277 \340\246\254\340\246\225\340\247\215\340\246\270\340\247\207 \340\246\270\340\247\207\340\246\260\340\246\276 \340\246\233\340\246\276\340\247\234</p>\n            </motion.div>\n          </div>\n\n          {/* Right Column: Narrative content */}\n          <div className=\"col-span-1 lg:col-span-7 text-left space-y-6\" id=\"banner-text-details\">\n            <span className=\"text-accent-gold text-xs font-bold uppercase tracking-widest font-sans\">\340\246\270\340\246\276\340\246\260\340\247\215\340\246\237\340\246\277\340\246\253\340\246\276\340\246\207\340\246\241 \340\246\255\340\247\207\340\246\267\340\246\234 \340\246\232\340\246\277\340\246\225\340\246\277\340\247\216\340\246\270\340\246\276</span>\n            <h3 className=\"text-2xl sm:text-3xl md:text-4xl font-display font-bold leading-tight\">\n              \340\246\270\340\247\201\340\246\270\340\247\215\340\246\245 \340\246\223 \340\246\270\340\246\244\340\247\207\340\246\234 \340\246\234\340\247\200\340\246\254\340\246\250\340\247\200\340\246\266\340\246\225\340\247\215\340\246\244\340\246\277 <br className=\"hidden sm:inline\" />\n              \340\246\253\340\246\277\340\246\260\340\247\207 \340\246\252\340\246\276\340\246\250 \340\246\270\340\246\256\340\247\215\340\246\252\340\247\202\340\246\260\340\247\215\340\246\243 \340\246\252\340\247\215\340\246\260\340\246\276\340\246\225\340\247\203\340\246\244\340\246\277\340\246\225 \340\246\211\340\246\252\340\246\276\340\247\237\340\247\207!\n            </h3>\n            <p className=\"text-sm sm:text-