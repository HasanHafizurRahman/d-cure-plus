    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import { Star, Quote } from \'lucide-react\';\nimport { reviewItems } from \'../data\';\nimport { motion } from \'motion/react\';\n\nexport default function CustomerReviews() {\n  return (\n    <section id=\"reviews\" className=\"py-16 md:py-24 bg-white\">\n      <div className=\"max-w-(--spacing-container-max) mx-auto px-4 sm:px-6 lg:px-8 text-center bangla-text\">\n        \n        {/* Title Block */}\n        <div className=\"max-w-xl mx-auto mb-16 space-y-3\">\n          <span className=\"text-brand-green text-xs font-bold uppercase tracking-wider font-sans\">\340\246\237\340\247\207\340\246\270\340\247\215\340\246\237\340\246\277\340\246\256\340\247\213\340\246\250\340\246\277\340\247\237\340\247\215\340\246\257\340\246\276\340\246\262</span>\n          <h2 className=\"text-2xl sm:text-3xl md:text-4xl font-display font-bold text-primary-dark tracking-tight\">\n            \340\246\227\340\247\215\340\246\260\340\246\276\340\246\271\340\246\225\340\246\246\340\247\207\340\246\260 \340\246\256\340\246\244\340\246\276\340\246\256\340\246\244\n          </h2>\n          <div className=\"w-12 h-1 bg-brand-green mx-auto rounded-full mt-2\"></div>\n        </div>\n\n        {/* Reviews Grid */}\n        <div className=\"grid grid-cols-1 md:grid-cols-3 gap-8\">\n          {reviewItems.map((review, idx) => (\n            <motion.div\n              key={review.id}\n              initial={{ opacity: 0, y: 15 }}\n              whileInView={{ opacity: 1, y: 0 }}\n              viewport={{ once: true, margin: \"-100px\" }}\n              transition={{ delay: idx * 0.1 }}\n              whileHover={{ scale: 1.02 }}\n              className=\"bg-slate-50 border border-slate-200 p-8 rounded-xl relative shadow-xs flex flex-col justify-between text-left\"\n              id={review.id}\n            >\n              <div className=\"space-y-4\">\n                {/* 5 Star Stars component */}\n                <div className=\"flex gap-1 text-accent-gold\" id={`stars-${review.id}`}>\n                  {[...Array(review.rating)].map((_, i) => (\n                    <Star key={i} size={18} className=\"fill-current stroke-none\" />\n                  ))}\n                </div>\n\n                {/* Narrative content */}\n                <p className=\"text-primary-dark/85 text-sm leading-relaxed font-sans relative z-10\">\n                  \342\200\234{review.text}\342\200\235\n                </p>\n              </div>\n\n              {/* Author Footer */}\n              <div className=\"mt-6 pt-4 border-t border-slate-200 text-right\">\n                <span className=\"text-sm font-display font-bold text-primary-dark\" id={`author-${review.id}`}>\n                  \342\200\224 {review.name}\n                </span>\n                <span className=\"block text-[10px] text-brand-green font-sans mt-0.5 font-semibold\">\340\246\255\340\247\207\340\246\260\340\246\277\340\246\253\340\246\276\340\246\207\340\246\241 \340\246\225\340\247\215\340\246\260\340\247\207\340\246\244\340\246\276</span>\n              </div>\n\n              {/* Graphic background quotes mark */}\n              <Quote size={48} className=\"absolute top-4 right-4 text-slate-200/50 -z-5\" />\n            </motion.div>\n          ))}\n        </div>\n\n      </div>\n    </section>\n  );\n}\n"
    }
