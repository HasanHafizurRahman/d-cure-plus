    replacement_chunks {
      replacement_content: "import { Eye, Shield, Package, CheckCircle2 } from \'lucide-react\';\nimport { motion } from \'motion/react\';\n\nexport default function WhyChooseUs() {\n  const cards = [\n    {\n      id: \"why-1\",\n      icon: <Eye className=\"text-brand-green w-6 h-6\" />,\n      title: \"\340\246\266\340\246\260\340\247\215\340\246\225\340\246\260\340\246\276 \340\246\250\340\246\277\340\247\237\340\246\250\340\247\215\340\246\244\340\247\215\340\246\260\340\246\243\",\n      description: \"\340\246\260\340\246\225\340\247\215\340\246\244\340\247\207 \340\246\227\340\247\215\340\246\262\340\247\201\340\246\225\340\247\213\340\246\234\340\247\207\340\246\260 \340\246\256\340\246\276\340\246\244\340\247\215\340\246\260\340\246\276 \340\246\270\340\247\215\340\246\254\340\246\276\340\246\255\340\246\276\340\246\254\340\246\277\340\246\225 \340\246\260\340\246\276\340\246\226\340\246\244\340\247\207 \340\246\217\340\246\237\340\246\277 \340\246\205\340\246\244\340\247\215\340\246\257\340\246\250\340\247\215\340\246\244 \340\246\225\340\246\276\340\246\260\340\247\215\340\246\257\340\246\225\340\246\260 \340\246\255\340\247\202\340\246\256\340\246\277\340\246\225\340\246\276 \340\246\252\340\246\276\340\246\262\340\246\250 \340\246\225\340\246\260\340\247\207\340\245\244\"\n    },\n    {\n      id: \"why-2\",\n      icon: <Shield className=\"text-[#a18100] w-6 h-6\" />,\n      title: \"\340\246\207\340\246\211\340\246\250\340\246\276\340\246\250\340\247\200 \340\246\253\340\246\260\340\247\215\340\246\256\340\247\201\340\246\262\340\246\276\",\n      description: \"Habbe ziabit 500 mg - \340\246\252\340\247\215\340\246\260\340\246\276\340\246\232\340\247\200\340\246\250 \340\246\207\340\246\211\340\246\250\340\246\276\340\246\250\340\247\200 \340\246\266\340\246\276\340\246\270\340\247\215\340\246\244\340\247\215\340\246\260\340\247\207\340\246\260 \340\246\217\340\246\225\340\246\237\340\246\277 \340\246\252\340\246\260\340\247\200\340\246\225\340\247\215\340\246\267\340\246\277\340\246\244 \340\246\217\340\246\254\340\246\202 \340\246\232\340\246\277\340\246\225\340\246\277\340\247\216\340\246\270\340\246\225\340\246\246\340\247\207\340\246\260 \340\246\246\340\247\215\340\246\254\340\246\276\340\246\260\340\246\276 \340\246\254\340\246\277\340\246\266\340\247\215\340\246\254\340\246\270\340\247\215\340\246\244 \340\246\224\340\246\267\340\246\247\340\245\244\"\n    },\n    {\n      id: \"why-3\",\n      icon: <Package className=\"text-primary-dark w-6 h-6\" />,\n      title: \"\340\247\247\340\247\250\340\247\246 \340\246\225\340\247\215\340\246\257\340\246\276\340\246\252\340\246\270\340\247\201\340\246\262\340\247\207\340\246\260 \340\246\252\340\247\215\340\246\257\340\246\276\340\246\225\",\n      description: \"\340\246\256\340\247\202\340\246\262\340\247\215\340\246\257: \340\247\263\340\247\247\340\247\250\340\247\246\340\247\246 (\340\247\247\340\247\250\340\247\246 \340\246\225\340\247\215\340\246\257\340\246\276\340\246\252\340\246\270\340\247\201\340\246\262)\340\245\244 \340\246\252\340\247\215\340\246\260\340\246\244\340\246\277\340\246\237\340\246\277 \340\246\254\340\246\225\340\247\215\340\246\270\340\247\207 \340\246\260\340\247\237\340\247\207\340\246\233\340\247\207 \340\247\247\340\247\250\340\247\246\340\246\237\340\246\277 \340\246\225\340\247\215\340\246\257\340\246\276\340\246\252\340\246\270\340\247\201\340\246\262, \340\246\257\340\246\276 \340\246\246\340\247\200\340\246\260\340\247\215\340\246\230\340\246\270\340\247\215\340\246\245\340\246\276\340\246\257\340\246\274\340\247\200 \340\246\254\340\247\215\340\246\257\340\246\254\340\246\271\340\246\276\340\246\260\340\247\207\340\246\260 \340\246\234\340\246\250\340\247\215\340\246\257 \340\246\211\340\246\252\340\246\257\340\247\201\340\246\225\340\247\215\340\246\244 \340\246\217\340\246\254\340\246\202 \340\246\270\340\246\276\340\246\266\340\247\215\340\246\260\340\247\237\340\247\200\340\245\244\"\n    }\n  ];\n\n  return (\n    <section id=\"benefits\" className=\"py-16 md:py-24 bg-white\">\n      <div className=\"max-w-(--spacing-container-max) mx-auto px-4 sm:px-6 lg:px-8 text-center bangla-text\">\n        \n        {/* Title Group */}\n        <div className=\"max-w-2xl mx-auto mb-16 space-y-4\">\n          <h2 className=\"text-2xl sm:text-3xl md:text-4xl font-display font-bold text-primary-dark tracking-tight\">\n            \340\246\225\340\247\207\340\246\250 D-CURE Plus \340\246\254\340\247\207\340\246\233\340\247\207 \340\246\250\340\246\277\340\246\254\340\247\207\340\246\250?\n          </h2>\n          <div className=\"w-16 h-1.5 bg-brand-green mx-auto rounded-full\"></div>\n          <p className=\"text-base sm:text-lg text-primary-dark/80 font-sans max-w-xl mx-auto\">\n            \340\246\211\340\246\232\340\247\215\340\246\232\340\246\256\340\246\276\340\246\250\340\247\207\340\246\260 \340\246\255\340\247\207\340\246\267\340\246\234 \340\246\211\340\246\252\340\246\276\340\246\246\340\246\276\340\246\250\340\247\207\340\246\260 \340\246\256\340\246\277\340\246\266\340\247\215\340\246\260\340\246\243\340\247\207 \340\246\244\340\247\210\340\246\260\340\246\277 \340\246\217\340\246\207 \340\246\225\340\247\215\340\246\257\340\246\276\340\246\252\340\246\270\340\247\201\340\246\262 \340\246\206\340\246\252\340\246\250\340\246\276\340\246\260 \340\246\270\340\247\201\340\246\270\340\247\215\340\246\245 \340\246\234\340\247\200\340\246\254\340\246\250\340\247\207\340\246\260 \340\246\217\340\246\225\340\246\256\340\246\276\340\246\244\340\247\215\340\246\260 \340\246\250\340\246\277\340\246\260\340\247\215\340\246\255\340\246\260\340\246\257\340\247\213\340\246\227\340\247\215\340\246\257 \340\246\270\340\246\231\340\247\215\340\246\227\340\247\200\340\245\244\n          </p>\n        </div>\n\n        {/* Benefits Grid */}\n        <div className=\"grid grid-cols-1 md:grid-cols-3 gap-8\">\n          {cards.map((card, idx) => (\n            <motion.div\n              key={card.id}\n              initial={{ opacity: 0, y: 15 }}\n              whileInView={{ opacity: 1, y: 0 }}\n              viewport={{ once: true, margin: \"-100px\" }}\n              transition={{ delay: idx * 0.15 }}\n              whileHover={{ y: -5 }}\n              className=\"flex flex-col items-center p-8 bg-slate-50 border border-slate-200 rounded-xl transition-all duration-300 hover:shadow-lg hover:border-brand-green group relative overflow-hidden text-center cursor-pointer\"\n              id={card.id}\n            >\n              <div className=\"absolute bottom-0 left-0 w-full h-1 bg-transparent group-hover:bg-accent-gold transition-colors duration-300\"></div>\n              \n              {/* Icon Container */}\n              <div className=\"w-14 h-14 bg-white shadow-xs rounded-full flex justify-center items-center border border-slate-100 mb-6 group-hover:scale-110 transition-transform duration-300\">\n                {card.icon}\n              </div>\n\n              {/* Title & Desc */}\n              <h3 className=\"text-xl font-display font-bold text-primary-dark mb-4\">\n                {card.title}\n              </h3>\n              <p className=\"text-primary-dark/80 text-sm leading-relaxed font-sans max-w-xs mx-auto\">\n                {card.description}\n              </p>\n            </motion.div>\n          ))}\n        </div>\n\n      </div>\n    </section>\n  );\n}\n"
    }
