          text: "              * \340\246\250\340\247\213\340\246\237: \340\246\207\340\246\211\340\246\250\340\246\276\340\246\250\340\247\200 \340\246\224\340\246\267\340\246\247 \340\246\270\340\246\256\340\247\215\340\246\252\340\247\202\340\246\260\340\247\215\340\246\243 \340\246\252\340\246\276\340\246\260\340\247\215\340\246\266\340\247\215\340\246\254\340\246\252\340\247\215\340\246\260\340\246\244\340\246\277\340\246\225\340\247\215\340\246\260\340\246\277\340\247\237\340\246\276\340\246\256\340\247\201\340\246\225\340\247\215\340\246\244\340\245\244 \340\246\244\340\246\254\340\247\207 \340\246\225\340\247\213\340\246\250\340\247\213 \340\246\246\340\247\200\340\246\260\340\247\215\340\246\230\340\246\270\340\247\215\340\246\245\340\246\276\340\247\237\340\247\200 \340\246\270\340\246\256\340\246\270\340\247\215\340\246\257\340\246\276 \340\246\245\340\246\276\340\246\225\340\246\262\340\247\207 \340\246\254\340\246\276 \340\246\205\340\246\250\340\247\215\340\246\257\340\246\276\340\246\250\340\247\215\340\246\257 \340\246\224\340\246\267\340\246\247 \340\246\270\340\247\207\340\246\254\340\246\250\340\247\207\340\246\260 \340\246\252\340\247\215\340\246\260\340\246\276\340\246\225\340\247\215\340\246\225\340\246\276\340\246\262\340\247\207 \340\246\232\340\246\277\340\246\225\340\246\277\340\247\216\340\246\270\340\246\225\340\247\207\340\246\260 \340\246\252\340\246\260\340\246\276\340\246\256\340\246\260\340\247\215\340\246\266 \340\246\227\340\247\215\340\246\260\340\246\271\340\246\243 \340\246\225\340\246\260\340\246\276 \340\246\254\340\246\276\340\246\236\340\247\215\340\246\233\340\246\250\340\247\200\340\247\237\340\245\244"
