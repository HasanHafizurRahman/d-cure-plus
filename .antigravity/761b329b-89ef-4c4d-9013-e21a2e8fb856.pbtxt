    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import { Sparkles, ArrowRight } from \'lucide-react\';\nimport { packageOptions } from \'../data\';\nimport { PackageOption } from \'../types\';\nimport { motion } from \'motion/react\';\n\ninterface PricingOffersProps {\n  onSelectPackage: (pkgId: \'single\' | \'double\') => void;\n  selectedPkgId: string;\n}\n\nexport default function PricingOffers({ onSelectPackage, selectedPkgId }: PricingOffersProps) {\n  \n  const handleSelect = (pkgId: \'single\' | \'double\') => {\n    onSelectPackage(pkgId);\n    const el = document.getElementById(\'checkout\');\n    if (el) {\n      el.scrollIntoView({ behavior: \'smooth\' });\n    }\n  };\n\n  return (\n    <section id=\"pricing\" className=\"py-16 md:py-24 bg-white border-t border-slate-200\">\n      <div className=\"max-w-(--spacing-container-max) mx-auto px-4 sm:px-6 lg:px-8 text-center bangla-text\">\n        \n        {/* Section Title */}\n        <div className=\"max-w-xl mx-auto mb-16 space-y-3\">\n          <h2 className=\"text-2xl sm:text-3xl md:text-4xl font-display font-bold text-primary-dark tracking-tight\">\n            \340\246\252\340\246\243\340\247\215\340\246\257\340\247\207\340\246\260 \340\246\256\340\247\202\340\246\262\340\247\215\340\246\257 \340\246\217\340\246\254\340\246\202 \340\246\205\340\246\253\340\246\276\340\246\260\n          </h2>\n          <p className=\"text-sm sm:text-base text-primary-dark/80 font-sans\">\n            \340\246\206\340\246\252\340\246\250\340\246\276\340\246\260 \340\246\252\340\247\215\340\246\260\340\247\237\340\247\213\340\246\234\340\246\250 \340\246\205\340\246\250\340\247\201\340\246\257\340\246\276\340\247\237\340\247\200 \340\246\270\340\247\207\340\246\260\340\246\276 \340\246\252\340\247\215\340\246\257\340\246\276\340\246\225\340\247\207\340\246\234\340\246\237\340\246\277 \340\246\254\340\247\207\340\246\233\340\247\207 \340\246\250\340\246\277\340\247\237\340\247\207 \340\246\260\340\246\225\340\247\215\340\246\244\340\247\207 \340\246\266\340\246\260\340\247\215\340\246\225\340\246\260\340\246\276 \340\246\250\340\246\277\340\247\237\340\246\250\340\247\215\340\246\244\340\247\215\340\246\260\340\246\243 \340\246\266\340\247\201\340\246\260\340\247\201 \340\246\225\340\246\260\340\247\201\340\246\250\n          </p>\n          <div className=\"w-12 h-1 bg-brand-green mx-auto rounded-full mt-2\"></div>\n        </div>\n\n        {/* Pricing Cards Grid */}\n        <div className=\"grid grid-cols-1 md:grid-cols-2 gap-8 max-w-3xl mx-auto items-stretch\">\n          \n          {packageOptions.map((pkg) => {\n            const isSelected = selectedPkgId === pkg.id;\n            return (\n              <motion.div\n                key={pkg.id}\n                initial={{ opacity: 0, y: 15 }}\n                whileInView={{ opacity: 1, y: 0 }}\n                viewport={{ once: true, margin: \"-50px\" }}\n                whileHover={{ scale: 1.02 }}\n                onClick={() => handleSelect(pkg.id as \'single\' | \'double\')}\n                className={`relative bg-white border rounded-2xl p-6 md:p-8 flex flex-col justify-between cursor-pointer transition-all duration-300 shadow-xs hover:shadow-lg ${\n                  pkg.isPopular \n                    ? \'border-accent-gold ring-2 ring-accent-gold/20\' \n                    : \'border-slate-200 hover:border-slate-350\'\n                } ${isSelected ? \'ring-2 ring-brand-green border-brand-green\' : \'\'}`}\n                id={`price-card-${pkg.id}`}\n              >\n                {/* Popular Corner Ribbon flag */}\n                {pkg.isPopular && (\n                  <div className=\"absolute top-0 right-0 overflow-hidden w-28 h-28 pointer-events-none\">\n                    <div className=\"absolute top-4 -right-10 bg-accent-gold text-accent-dark-gold text-[10px] sm:text-xs font-display font-bold py-1.5 px-10 text-center uppercase tracking-wider transform rotate-45 shadow-sm\">\n                      \340\246\270\340\247\207\340\246\260\340\246\276 \340\246\205\340\246\253\340\246\276\340\246\260\n                    </div>\n                  </div>\n                )}\n\n                {/* Card Content */}\n                <div className=\"space-y-6 text-center\">\n                  \n                  {/* Virtual Product Bottles Icon Graphic */}\n                  <div className=\"flex justify-center items-center py-4\">\n                    {pkg.id === \'single\' ? (\n                      /* 1 Bottle Rendering */\n                      <div className=\"relative w-24 h-32 flex flex-col justify-between bg-white border-2 border-slate-200 rounded-lg shadow-sm overflow-hidden p-1\">\n                        <div className=\"h-4 bg-primary-dark rounded-xs\"></div>\n                        <div className=\"flex-1 flex flex-col items-center justify-center p-1 font-display\">\n                          <span className=\"text-[10px] font-bold text-primary-dark\">D-CURE</span>\n                          <span className=\"text-[8px] bg-brand-green text-white px-1 rounded-sm leading-none mt-0.5\">PLUS</span>\n                          <span className=\"text-[7px] text-[#745c00] font-sans mt-1\">120 Capsules</span>\n                        </div>\n                      </div>\n                    ) : (\n                      /* 2 Bottles Rendering representing double deal */\n                      <div className=\"relative flex items-end gap-2\">\n                        {/* Left small helper bottle */}\n                        <div className=\"relative w-18 h-24 flex flex-col justify-between bg-white border-2 border-slate-200 rounded-md shadow-xs overflow-hidden p-1 transform -rotate-6 translate-x-2\">\n                          <div className=\"h-3 bg-primary-dark rounded-xs\"></div>\n                          <div className=\"flex-1 flex flex-col items-center justify-center p-1 font-display scale-90\">\n                            <span className=\"text-[8px] font-bold text-primary-dark\">D-CURE</span>\n                            <span className=\"text-[6px] bg-brand-green text-white px-0.5 rounded-sm shrink-0\">PLUS</span>\n                          </div>\n                        </div>\n                        {/* Right Main Bottle */}\n                        <div className=\"relative w-24 h-32 flex flex-col justify-between bg-white border-2 border-slate-300 rounded-lg shadow-md overflow-hidden p-1 z-10\">\n                          <div className=\"h-4 bg-primary-dark rounded-xs\"></div>\n                          <div className=\"flex-1 flex flex-col items-center justify-center p-1 font-display\">\n                            <span className=\"text-[10px] font-bold text-primary-dark\">D-CURE</span>\n                            <span className=\"text-[8px] bg-brand-green text-white px-1 rounded-sm leading-none mt-0.5\">PLUS</span>\n                            <span className=\"text-[7px] text-[#745c00] font-sans mt-1\">120 Capsules</span>\n                          </div>\n                        </div>\n                      </div>\n                    )}\n                  </div>\n\n                  {/* Title & Badge */}\n                  <div className=\"space-y-2\">\n                    <span className=\"inline-block bg-[#003520]/5 text-[#003520] font-display text-[11px] font-bold px-3 py-1 rounded-full border border-[#003520]/10\">\n                      {pkg.label}\n                    </span>\n                    <h3 className=\"text-xl sm:text-2xl font-display font-bold text-primary-dark\">\n                      {pkg.title}\n                    </h3>\n                  </div>\n\n                  {/* Price Area */}\n                  <div className=\"space-y-1\">\n                    <div className=\"text-3xl sm:text-4xl font-display font-bold text-brand-green\">\n                      \340\247\263{pkg.price}\n                    </div>\n                    {pkg.savings && (\n                      <div className=\"text-xs sm:text-sm text-primary-dark/70 font-sans flex items-center justify-center gap-1.5\">\n                        <span className=\"line-through text-brand-red font-display\">\340\247\263{pkg.originalPrice}</span>\n                        <span className=\"bg-brand-red/10 text-brand-red px-2 py-0.5 rounded-md font-semibold\">\n                          \340\247\263{pkg.savings} \340\246\270\340\246\276\340\246\266\340\247\215\340\246\260\340\247\237!\n                        </span>\n                      </div>\n                    )}\n                  </div>\n                </div>\n\n                {/* Bottom Order Button Trigger */}\n                <div className=\"mt-8 pt-4 border-t border-slate-100\">\n                  <button\n                    onClick={() => handleSelect(pkg.id as \'single\' | \'double\')}\n                    className={`w-full flex items-center justify-center py-3 rounded-md font-display font-bold text-sm transition-all duration-200 cursor-pointer ${\n                      pkg.isPopular \n                        ? \'bg-primary-dark hover:bg-primary-medium text-white shadow-md\' \n                        : \'bg-white border border-primary-dark text-primary-dark hover:bg-slate-50\'\n                    }`}\n                  >\n                    \340\246\252\340\247\215\340\246\257\340\246\276\340\246\225\340\247\207\340\246\234\340\246\237\340\246\277 \340\246\254\340\247\207\340\246\233\340\247\207 \340\246\250\340\246\277\340\246\250\n                    <ArrowRight size={16} className=\"ml-1.5\" />\n                  </button>\n                </div>\n\n              </motion.div>\n            );\n          })}\n\n        </div>\n\n      </div>\n    </section>\n  );\n}\n"
    }
